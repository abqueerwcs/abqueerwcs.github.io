---
layout: base.njk
title: Board Members
permalink: /board/
---

<section class="container">
  <h1>Board Members</h1>

  <div class="board-list">

    {% for member in board %}
      <div class="card board-member">

        <!-- Photo -->
        <div class="member-photo-wrapper">
          <img
            src="{{ member.image }}"
            alt="{{ member.name }}"
            class="member-photo"
          >

          {% if member.photoCredit %}
            <p class="photo-credit">{{ member.photoCredit }}</p>
          {% endif %}
        </div>

        <!-- Info -->
        <div class="member-info">
          <h2>{{ member.name }}</h2>
          <h3 class="member-role">{{ member.role }}</h3>
          <p>{{ member.bio }}</p>
        </div>

      </div>
    {% endfor %}

  </div>
</section>
