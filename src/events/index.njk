{% from "event-card.njk" import render as eventCard %}

<section class="container">
  <h1>Events</h1>

  <h4>Check out our <u><a href="/events/calendar/">Google Calendar</a></u>!</h4>
  <p>For any parking questions check out the <u><a href="/events/parking/">Parking Map</a></u> for the Peace Love Space.</p>

  <div class="events-list">
    {% for event in upcomingEvents %}
      {{ eventCard(event, highlight=loop.first, showMeta=true) }}
    {% endfor %}

    <h4>View our <u><a href="/events/past/">past events</a></u>!</h4>
  </div>

  {% include "lightbox.njk" %}
</section>
